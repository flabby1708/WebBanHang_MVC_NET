@model SV22T1020497.Admin.Models.OrderDetailsViewModel
@{
    ViewBag.Title = "Chi tiết đơn hàng";
    string badgeClass = Model.Order.Status switch
    {
        OrderStatusEnum.New => "alert-warning",
        OrderStatusEnum.Accepted => "alert-info",
        OrderStatusEnum.Shipping => "alert-primary",
        OrderStatusEnum.Completed => "alert-success",
        OrderStatusEnum.Rejected => "alert-danger",
        OrderStatusEnum.Cancelled => "alert-secondary",
        _ => "alert-secondary"
    };
}
@section PageToolBar {
    @if (Model.Order.Status == OrderStatusEnum.New)
    {
        <a href="~/Order/Accept/@Model.Order.OrderID" class="btn btn-info open-modal"><i class="bi bi-check2-circle"></i> Duyệt</a>
        <a href="~/Order/Reject/@Model.Order.OrderID" class="btn btn-danger open-modal ms-1"><i class="bi bi-x-circle"></i> Từ chối</a>
        <a href="~/Order/Cancel/@Model.Order.OrderID" class="btn btn-warning open-modal ms-1"><i class="bi bi-slash-circle"></i> Hủy</a>
        <a href="~/Order/Delete/@Model.Order.OrderID" class="btn btn-outline-danger open-modal ms-1"><i class="bi bi-trash"></i> Xóa</a>
    }
    else if (Model.Order.Status == OrderStatusEnum.Accepted)
    {
        <a href="~/Order/Shipping/@Model.Order.OrderID" class="btn btn-primary open-modal"><i class="bi bi-truck"></i> Giao hàng</a>
        <a href="~/Order/Cancel/@Model.Order.OrderID" class="btn btn-warning open-modal ms-1"><i class="bi bi-slash-circle"></i> Hủy</a>
    }
    else if (Model.Order.Status == OrderStatusEnum.Shipping)
    {
        <a href="~/Order/Finish/@Model.Order.OrderID" class="btn btn-success open-modal"><i class="bi bi-check2-square"></i> Hoàn tất</a>
    }
    else if (Model.Order.Status == OrderStatusEnum.Rejected || Model.Order.Status == OrderStatusEnum.Cancelled)
    {
        <a href="~/Order/Delete/@Model.Order.OrderID" class="btn btn-outline-danger open-modal"><i class="bi bi-trash"></i> Xóa</a>
    }

    <a href="~/Order" class="btn btn-secondary ms-1"><i class="bi bi-arrow-left"></i> Quay lại</a>
}
<div class="alert @badgeClass d-flex align-items-center mb-3">
    <i class="bi bi-info-circle-fill fs-4 me-2"></i>
    <div>
        <strong>Trạng thái đơn hàng:</strong>
        @Model.Order.Status.GetDescription()
    </div>
</div>
<div class="card card-primary card-outline mb-3">
    <div class="card-header"><h5 class="card-title mb-0"><i class="bi bi-receipt me-2"></i> Thông tin đơn hàng</h5></div>
    <div class="card-body ps-4 pe-4">
        <div class="row mb-2">
            <div class="col-md-3 fw-bold">Mã đơn hàng</div><div class="col-md-3">@Model.Order.OrderID</div>
            <div class="col-md-3 fw-bold">Ngày lập</div><div class="col-md-3">@Model.Order.OrderTime.ToString("dd/MM/yyyy HH:mm")</div>
        </div>
        <div class="row">
            <div class="col-md-3 fw-bold">Nhân viên phụ trách</div><div class="col-md-3">@(string.IsNullOrWhiteSpace(Model.Order.EmployeeName) ? "--" : Model.Order.EmployeeName)</div>
            <div class="col-md-3 fw-bold">Ngày nhận đơn</div><div class="col-md-3">@(Model.Order.AcceptTime?.ToString("dd/MM/yyyy HH:mm") ?? "--")</div>
        </div>
    </div>
</div>
<div class="card card-info card-outline mb-3">
    <div class="card-header"><h5 class="card-title mb-0"><i class="bi bi-person me-2"></i> Thông tin khách hàng</h5></div>
    <div class="card-body ps-4 pe-4">
        <div class="row mb-2">
            <div class="col-md-3 fw-bold">Khách hàng</div><div class="col-md-3">@Model.Order.CustomerName</div>
            <div class="col-md-3 fw-bold">Tên giao dịch</div><div class="col-md-3">@Model.Order.CustomerContactName</div>
        </div>
        <div class="row mb-2"><div class="col-md-3 fw-bold">Email</div><div class="col-md-9">@Model.Order.CustomerEmail</div></div>
        <div class="row"><div class="col-md-3 fw-bold">Địa chỉ</div><div class="col-md-9">@Model.Order.CustomerAddress</div></div>
    </div>
</div>
<div class="card card-success card-outline mb-3">
    <div class="card-header"><h5 class="card-title mb-0"><i class="bi bi-truck me-2"></i> Thông tin giao hàng</h5></div>
    <div class="card-body ps-4 pe-4">
        <div class="row mb-2">
            <div class="col-md-3 fw-bold">Người giao hàng</div><div class="col-md-3">@(string.IsNullOrWhiteSpace(Model.Order.ShipperName) ? "--" : Model.Order.ShipperName)</div>
            <div class="col-md-3 fw-bold">Điện thoại</div><div class="col-md-3">@(string.IsNullOrWhiteSpace(Model.Order.ShipperPhone) ? "--" : Model.Order.ShipperPhone)</div>
        </div>
        <div class="row mb-2"><div class="col-md-3 fw-bold">Địa chỉ giao hàng</div><div class="col-md-9">@Model.Order.DeliveryAddress</div></div>
        <div class="row"><div class="col-md-3 fw-bold">Tỉnh / Thành</div><div class="col-md-9">@Model.Order.DeliveryProvince</div></div>
    </div>
</div>
<div class="card card-secondary card-outline">
    <div class="card-header"><h5 class="card-title mb-0"><i class="bi bi-box-seam me-2"></i> Danh sách mặt hàng</h5></div>
    <div class="card-body table-responsive">
        <table class="table table-bordered table-hover align-middle">
            <thead class="table-secondary text-center">
                <tr>
                    <th>STT</th><th>Tên hàng</th><th>ĐVT</th><th>Số lượng</th><th>Giá</th><th>Thành tiền</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Details.Any())
                {
                    int index = 1;
                    foreach (var item in Model.Details)
                    {
                        <tr>
                            <td class="text-center">@index</td>
                            <td>@item.ProductName</td>
                            <td class="text-center">@item.Unit</td>
                            <td class="text-center">@item.Quantity</td>
                            <td class="text-end">@item.SalePrice.ToString("N0")</td>
                            <td class="text-end">@item.TotalPrice.ToString("N0")</td>
                        </tr>
                        index++;
                    }
                }
                else
                {
                    <tr>
                        <td colspan="6" class="text-center text-muted py-4">Đơn hàng chưa có mặt hàng nào.</td>
                    </tr>
                }
            </tbody>
            <tfoot>
                <tr><th colspan="5" class="text-end">Tổng cộng</th><th class="text-end">@Model.TotalAmount.ToString("N0")</th></tr>
            </tfoot>
        </table>
    </div>
</div>
@section Styles {
    <style>
        .card-body .row { border-bottom: 1px dotted #646464; }
    </style>
}
