@model SV22T1020497.Models.Sales.OrderViewInfo
@{
    Layout = null;
    var returnAction = Context.Request.Query["returnAction"].ToString();
    if (string.IsNullOrWhiteSpace(returnAction))
    {
        returnAction = "Detail";
    }
}
<form method="post" asp-action="Cancel">
    @Html.AntiForgeryToken()
    <input type="hidden" name="id" value="@Model.OrderID" />
    <input type="hidden" name="returnAction" value="@returnAction" />
    <div class="modal-header text-bg-warning">
        <strong class="modal-title">Xác nhận hủy đơn hàng</strong>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
    </div>
    <div class="modal-body">
        <div class="alert alert-warning d-flex align-items-center mb-0">
            <i class="bi bi-info-circle me-2"></i>
            <span>Bạn có thực sự muốn hủy đơn hàng <strong>#@Model.OrderID</strong> hay không?</span>
        </div>
    </div>
    <div class="modal-footer">
        <button type="submit" class="btn btn-primary"><i class="bi bi-check"></i> Chấp nhận</button>
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Đóng</button>
    </div>
</form>
