@model SV22T1020497.Models.Sales.OrderViewInfo
@using SV22T1020497.Models.Partner
@{
    Layout = null;
    var shippers = ViewBag.Shippers as List<Shipper> ?? new List<Shipper>();
}
<form method="post" asp-action="Shipping">
    @Html.AntiForgeryToken()
    <input type="hidden" name="id" value="@Model.OrderID" />
    <input type="hidden" name="returnAction" value="Detail" />
    <div class="modal-header text-bg-info">
        <strong class="modal-title">Chọn người giao hàng</strong>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
    </div>
    <div class="modal-body">
        <div class="mb-3">
            <label class="form-label">Người giao hàng</label>
            <select class="form-select" name="shipperId" required>
                <option value="0">-- Chọn người giao hàng --</option>
                @foreach (var shipper in shippers)
                {
                    <option value="@shipper.ShipperID">@shipper.ShipperName@(string.IsNullOrWhiteSpace(shipper.Phone) ? "" : $" - {shipper.Phone}")</option>
                }
            </select>
        </div>
    </div>
    <div class="modal-footer">
        <button type="submit" class="btn btn-primary"><i class="bi bi-bicycle"></i> Giao hàng</button>
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Đóng</button>
    </div>
</form>
