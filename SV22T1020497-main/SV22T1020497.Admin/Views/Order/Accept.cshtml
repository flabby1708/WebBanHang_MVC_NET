@model SV22T1020497.Models.Sales.OrderViewInfo
@{
    Layout = null;
}
<form method="post" asp-action="Accept">
    @Html.AntiForgeryToken()
    <input type="hidden" name="id" value="@Model.OrderID" />
    <input type="hidden" name="returnAction" value="Detail" />
    <div class="modal-header text-bg-info">
        <strong class="modal-title">Duyệt chấp nhận đơn hàng</strong>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
    </div>
    <div class="modal-body">
        <div class="alert alert-info d-flex align-items-center mb-0">
            <i class="bi bi-info-circle me-2"></i>
            <span>Bạn có chắc chắn muốn duyệt đơn hàng <strong>#@Model.OrderID</strong> không?</span>
        </div>
    </div>
    <div class="modal-footer">
        <button type="submit" class="btn btn-primary"><i class="bi bi-check"></i> Chấp nhận</button>
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Đóng</button>
    </div>
</form>
