@model SV22T1020497.Models.Sales.OrderDetailViewInfo
@{
    Layout = null;
}
<form method="post" asp-action="DeleteCartItem">
    @Html.AntiForgeryToken()
    <input type="hidden" name="productId" value="@Model.ProductID" />
    <input type="hidden" name="searchValue" value="@ViewBag.SearchValue" />
    <input type="hidden" name="page" value="@ViewBag.Page" />
    <input type="hidden" name="customerId" value="@ViewBag.CustomerID" />
    <input type="hidden" name="deliveryProvince" value="@ViewBag.DeliveryProvince" />
    <input type="hidden" name="deliveryAddress" value="@ViewBag.DeliveryAddress" />

    <div class="modal-header text-bg-danger">
        <strong class="modal-title">Xóa mặt hàng khỏi đơn hàng</strong>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
    </div>
    <div class="modal-body">
        <div class="alert alert-danger d-flex align-items-center mb-0">
            <i class="bi bi-info-circle me-2"></i>
            Bạn có muốn xóa mặt hàng <strong class="ms-1">@Model.ProductName</strong> ra khỏi đơn hàng không?
        </div>
    </div>
    <div class="modal-footer">
        <button type="submit" class="btn btn-primary"><i class="bi bi-check"></i> Chấp nhận</button>
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Đóng</button>
    </div>
</form>
