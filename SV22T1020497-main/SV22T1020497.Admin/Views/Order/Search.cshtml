@model SV22T1020497.Admin.Models.OrderSearchResultViewModel
@{
    Layout = null;
}
<div class="mb-2 text-muted">
    Danh sách này có <strong>@Model.Data.RowCount</strong> đơn hàng
</div>
<div class="card">
    <div class="card-body p-1">
        <table class="table table-bordered table-hover mb-0 align-middle">
            <thead class="table-secondary">
                <tr>
                    <th>Ngày đặt hàng</th>
                    <th>Tên khách hàng</th>
                    <th>Điện thoại</th>
                    <th>Ngày duyệt</th>
                    <th>Nhân viên xử lý</th>
                    <th class="text-end">Tổng tiền</th>
                    <th class="text-center" style="width:160px;">Trạng thái</th>
                    <th class="text-center" style="width:40px"></th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Data.DataItems.Any())
                {
                    foreach (var item in Model.Data.DataItems)
                    {
                        string badgeClass = item.Status switch
                        {
                            OrderStatusEnum.New => "bg-warning text-dark",
                            OrderStatusEnum.Accepted => "bg-info",
                            OrderStatusEnum.Shipping => "bg-primary",
                            OrderStatusEnum.Completed => "bg-success",
                            OrderStatusEnum.Rejected => "bg-danger",
                            OrderStatusEnum.Cancelled => "bg-secondary",
                            _ => "bg-secondary"
                        };

                        <tr>
                            <td>@item.OrderTime.ToString("dd/MM/yyyy HH:mm")</td>
                            <td>@item.CustomerName</td>
                            <td>@item.CustomerPhone</td>
                            <td>@(item.AcceptTime?.ToString("dd/MM/yyyy HH:mm") ?? "--")</td>
                            <td>@(string.IsNullOrWhiteSpace(item.EmployeeName) ? "--" : item.EmployeeName)</td>
                            <td class="text-end">@(Model.OrderTotals.ContainsKey(item.OrderID) ? Model.OrderTotals[item.OrderID].ToString("N0") : "0")</td>
                            <td class="text-center">
                                <span class="badge @badgeClass">@item.Status.GetDescription()</span>
                            </td>
                            <td class="text-center text-nowrap">
                                <a href="~/Order/Detail/@item.OrderID" class="btn btn-sm btn-primary">
                                    <i class="bi bi-receipt"></i>
                                </a>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="8" class="text-center text-muted py-4">Không tìm thấy đơn hàng phù hợp.</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    @if (Model.Data.PageCount > 1)
    {
        <div class="card-footer">
            <ul class="pagination justify-content-center mb-0">
                @for (int p = 1; p <= Model.Data.PageCount; p++)
                {
                    <li class="page-item @(p == Model.Data.Page ? "active" : "")">
                        <a class="page-link"
                           href="javascript:;"
                           onclick="paginationSearch(event, document.getElementById('formSearch'), @p)">
                            @p
                        </a>
                    </li>
                }
            </ul>
        </div>
    }
</div>
