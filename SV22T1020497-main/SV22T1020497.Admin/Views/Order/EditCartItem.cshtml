@model SV22T1020497.Models.Sales.OrderDetailViewInfo
@{
    Layout = null;
    var photo = string.IsNullOrWhiteSpace(Model.Photo) ? "nophoto.png" : Model.Photo;
}
<form method="post" asp-action="EditCartItem">
    @Html.AntiForgeryToken()
    <input type="hidden" name="productId" value="@Model.ProductID" />
    <input type="hidden" name="searchValue" value="@ViewBag.SearchValue" />
    <input type="hidden" name="page" value="@ViewBag.Page" />
    <input type="hidden" name="customerId" value="@ViewBag.CustomerID" />
    <input type="hidden" name="deliveryProvince" value="@ViewBag.DeliveryProvince" />
    <input type="hidden" name="deliveryAddress" value="@ViewBag.DeliveryAddress" />

    <div class="modal-header">
        <strong class="modal-title">Cập nhật chi tiết đơn hàng</strong>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
    </div>
    <div class="modal-body">
        <div class="container-fluid">
            <div class="row">
                <div class="col-md-8">
                    <div class="row mb-3 align-items-center">
                        <label class="col-sm-4 col-form-label fw-semibold">Mặt hàng</label>
                        <div class="col-sm-8">
                            <input type="text" class="form-control-plaintext fw-bold" value="@Model.ProductName" readonly>
                        </div>
                    </div>
                    <div class="row mb-3 align-items-center">
                        <label class="col-sm-4 col-form-label fw-semibold">Số lượng</label>
                        <div class="col-sm-5">
                            <input type="number" name="quantity" class="form-control text-end" min="1" value="@Model.Quantity">
                        </div>
                    </div>
                    <div class="row mb-3 align-items-center">
                        <label class="col-sm-4 col-form-label fw-semibold">Đơn giá</label>
                        <div class="col-sm-5">
                            <input type="text" name="salePrice" class="form-control text-end money-input" value="@Model.SalePrice">
                        </div>
                    </div>
                </div>
                <div class="col-md-4 text-end">
                    <img src="~/images/products/@photo" alt="@Model.ProductName" class="img-thumbnail" style="max-height:180px">
                </div>
            </div>
        </div>
    </div>
    <div class="modal-footer">
        <button type="submit" class="btn btn-primary">Cập nhật</button>
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Đóng</button>
    </div>
</form>
