<section class="dashboard-hero">
    <div class="dashboard-hero__content">
        <span class="dashboard-hero__eyebrow">Tổng quan vận hành</span>
        <h2>Kiểm soát toàn bộ bán hàng, hàng hóa và khách hàng trong một màn hình.</h2>
        <p>Giao diện mới tập trung vào các chỉ số quan trọng, tiến độ xử lý đơn và những nhóm dữ liệu cần thao tác nhiều nhất mỗi ngày.</p>
    </div>
    <div class="dashboard-hero__stat">
        <span>Hiệu suất hôm nay</span>
        <strong>92%</strong>
        <small>Đơn hàng đang được xử lý đúng tiến độ</small>
    </div>
</section>

<div class="row g-4">
    <div class="col-xl-3 col-md-6">
        <article class="dashboard-metric dashboard-metric--primary">
            <div>
                <span class="dashboard-metric__label">Doanh thu hôm nay</span>
                <strong class="dashboard-metric__value">12.500.000 đ</strong>
                <small class="dashboard-metric__trend text-success">+18% so với hôm qua</small>
            </div>
            <i class="bi bi-cash-coin"></i>
        </article>
    </div>
    <div class="col-xl-3 col-md-6">
        <article class="dashboard-metric dashboard-metric--emerald">
            <div>
                <span class="dashboard-metric__label">Đơn hàng</span>
                <strong class="dashboard-metric__value">48</strong>
                <small class="dashboard-metric__trend">12 đơn chờ xác nhận</small>
            </div>
            <i class="bi bi-bag-check"></i>
        </article>
    </div>
    <div class="col-xl-3 col-md-6">
        <article class="dashboard-metric dashboard-metric--amber">
            <div>
                <span class="dashboard-metric__label">Khách hàng</span>
                <strong class="dashboard-metric__value">320</strong>
                <small class="dashboard-metric__trend">28 khách quay lại trong tuần</small>
            </div>
            <i class="bi bi-people"></i>
        </article>
    </div>
    <div class="col-xl-3 col-md-6">
        <article class="dashboard-metric dashboard-metric--rose">
            <div>
                <span class="dashboard-metric__label">Sản phẩm</span>
                <strong class="dashboard-metric__value">128</strong>
                <small class="dashboard-metric__trend">09 mã sắp hết tồn</small>
            </div>
            <i class="bi bi-box-seam"></i>
        </article>
    </div>
</div>

<div class="row g-4 mt-1">
    <div class="col-xl-8">
        <section class="admin-surface dashboard-panel">
            <div class="dashboard-panel__header">
                <div>
                    <span class="dashboard-panel__eyebrow">Doanh thu</span>
                    <h3>Xu hướng 6 tháng gần nhất</h3>
                </div>
                <span class="dashboard-panel__badge">Cập nhật theo tháng</span>
            </div>
            <div class="dashboard-chart">
                <canvas id="revenueChart"></canvas>
            </div>
        </section>
    </div>
    <div class="col-xl-4">
        <section class="admin-surface dashboard-panel">
            <div class="dashboard-panel__header">
                <div>
                    <span class="dashboard-panel__eyebrow">Bán chạy</span>
                    <h3>Top sản phẩm</h3>
                </div>
            </div>
            <div class="dashboard-ranking">
                <div class="dashboard-ranking__item">
                    <div>
                        <strong>Laptop Dell</strong>
                        <span>Dòng văn phòng</span>
                    </div>
                    <b>120</b>
                </div>
                <div class="dashboard-ranking__item">
                    <div>
                        <strong>iPhone 15</strong>
                        <span>Doanh số ổn định</span>
                    </div>
                    <b>98</b>
                </div>
                <div class="dashboard-ranking__item">
                    <div>
                        <strong>Tai nghe Sony</strong>
                        <span>Tăng mạnh cuối tuần</span>
                    </div>
                    <b>76</b>
                </div>
                <div class="dashboard-ranking__item">
                    <div>
                        <strong>Chuột Logitech</strong>
                        <span>Biên lợi nhuận tốt</span>
                    </div>
                    <b>65</b>
                </div>
            </div>
        </section>
    </div>
</div>

<div class="row g-4 mt-1">
    <div class="col-12">
        <section class="admin-surface dashboard-panel">
            <div class="dashboard-panel__header">
                <div>
                    <span class="dashboard-panel__eyebrow">Theo dõi</span>
                    <h3>Đơn hàng cần xử lý</h3>
                </div>
                <a href="~/Order" class="dashboard-panel__link">Xem tất cả</a>
            </div>

            <div class="table-responsive">
                <table class="table admin-table mb-0 align-middle">
                    <thead>
                        <tr>
                            <th>Mã đơn</th>
                            <th>Khách hàng</th>
                            <th>Ngày</th>
                            <th class="text-end">Tổng tiền</th>
                            <th>Trạng thái</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td><strong>#DH00125</strong></td>
                            <td>Nguyễn Văn A</td>
                            <td>01/02/2026</td>
                            <td class="text-end">3.500.000 đ</td>
                            <td><span class="badge text-bg-danger">Đang chờ duyệt</span></td>
                        </tr>
                        <tr>
                            <td><strong>#DH00126</strong></td>
                            <td>Trần Thị B</td>
                            <td>01/02/2026</td>
                            <td class="text-end">1.200.000 đ</td>
                            <td><span class="badge text-bg-warning">Chờ giao hàng</span></td>
                        </tr>
                        <tr>
                            <td><strong>#DH00127</strong></td>
                            <td>Lê Văn C</td>
                            <td>31/01/2026</td>
                            <td class="text-end">8.900.000 đ</td>
                            <td><span class="badge text-bg-info">Đã đóng gói</span></td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </section>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        const ctx = document.getElementById('revenueChart');

        new Chart(ctx, {
            type: 'line',
            data: {
                labels: ['Tháng 1', 'Tháng 2', 'Tháng 3', 'Tháng 4', 'Tháng 5', 'Tháng 6'],
                datasets: [{
                    label: 'Doanh thu (triệu đồng)',
                    data: [120, 150, 180, 140, 200, 220],
                    fill: true,
                    tension: 0.35,
                    borderColor: '#2563eb',
                    backgroundColor: 'rgba(37, 99, 235, 0.12)',
                    pointBackgroundColor: '#1d4ed8',
                    pointRadius: 4,
                    pointHoverRadius: 5
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    legend: {
                        display: true,
                        position: 'top'
                    }
                },
                scales: {
                    y: {
                        beginAtZero: true,
                        grid: {
                            color: 'rgba(148, 163, 184, 0.18)'
                        }
                    },
                    x: {
                        grid: {
                            display: false
                        }
                    }
                }
            }
        });
    </script>
}
