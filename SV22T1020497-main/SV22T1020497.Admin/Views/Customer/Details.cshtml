@model SV22T1020497.Admin.Models.CustomerDetailsViewModel
@{
    ViewBag.Title = "Chi tiết khách hàng";
}

@section PageToolBar {
    <a href="~/Customer/Orders/@Model.Customer.CustomerID" class="btn btn-info">
        <i class="bi bi-receipt me-1"></i>
        Xem đơn hàng
    </a>
    <a href="~/Customer/Edit/@Model.Customer.CustomerID" class="btn btn-primary ms-1">
        <i class="bi bi-pencil me-1"></i>
        Chỉnh sửa
    </a>
    <a href="~/Customer" class="btn btn-secondary ms-1">
        <i class="bi bi-arrow-left"></i>
        Quay lại
    </a>
}

<div class="row">
    <div class="col-lg-8">
        <div class="card card-primary card-outline mb-3">
            <div class="card-header">
                <h5 class="card-title mb-0">
                    <i class="bi bi-person-vcard me-2"></i>
                    Hồ sơ khách hàng
                </h5>
            </div>
            <div class="card-body">
                <dl class="row mb-0">
                    <dt class="col-sm-4">Tên khách hàng</dt>
                    <dd class="col-sm-8">@Model.Customer.CustomerName</dd>

                    <dt class="col-sm-4">Tên giao dịch</dt>
                    <dd class="col-sm-8">@Model.Customer.ContactName</dd>

                    <dt class="col-sm-4">Điện thoại</dt>
                    <dd class="col-sm-8">@Model.Customer.Phone</dd>

                    <dt class="col-sm-4">Email</dt>
                    <dd class="col-sm-8">@Model.Customer.Email</dd>

                    <dt class="col-sm-4">Địa chỉ</dt>
                    <dd class="col-sm-8">@Model.Customer.Address</dd>

                    <dt class="col-sm-4">Tỉnh / Thành</dt>
                    <dd class="col-sm-8">@Model.Customer.Province</dd>

                    <dt class="col-sm-4">Trạng thái</dt>
                    <dd class="col-sm-8">
                        @if (Model.Customer.IsLocked == true)
                        {
                            <span class="badge bg-danger">Khóa</span>
                        }
                        else
                        {
                            <span class="badge bg-success">Hoạt động</span>
                        }
                    </dd>
                </dl>
            </div>
        </div>
    </div>

    <div class="col-lg-4">
        <div class="card card-info card-outline">
            <div class="card-header">
                <h5 class="card-title mb-0">
                    <i class="bi bi-bar-chart me-2"></i>
                    Thống kê nhanh
                </h5>
            </div>
            <div class="card-body">
                <div class="mb-3">
                    <div class="text-muted small">Tổng số đơn hàng</div>
                    <div class="fs-4 fw-semibold">@Model.TotalOrders</div>
                </div>
                <div class="mb-3">
                    <div class="text-muted small">Tổng chi tiêu</div>
                    <div class="fs-4 fw-semibold">@Model.TotalSpent.ToString("N0") đ</div>
                </div>
                <div>
                    <div class="text-muted small">Đơn gần nhất</div>
                    <div class="fw-semibold">
                        @(Model.LastOrderTime.HasValue ? Model.LastOrderTime.Value.ToString("dd/MM/yyyy") : "Chưa có đơn hàng")
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
