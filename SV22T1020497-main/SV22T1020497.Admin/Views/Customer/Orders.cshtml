@model SV22T1020497.Admin.Models.CustomerOrdersViewModel
@{
    ViewBag.Title = "Đơn hàng của khách hàng";
}

@section PageToolBar {
    <a href="~/Customer/Details/@Model.Customer.CustomerID" class="btn btn-info">
        <i class="bi bi-person-lines-fill me-1"></i>
        Xem hồ sơ
    </a>
    <a href="~/Customer" class="btn btn-secondary ms-1">
        <i class="bi bi-arrow-left"></i>
        Quay lại
    </a>
}

<div class="card mb-3">
    <div class="card-body">
        <div class="row">
            <div class="col-md-4">
                <div class="text-muted small">Khách hàng</div>
                <div class="fw-semibold">@Model.Customer.CustomerName</div>
            </div>
            <div class="col-md-4">
                <div class="text-muted small">Liên hệ</div>
                <div class="fw-semibold">@Model.Customer.ContactName</div>
            </div>
            <div class="col-md-4">
                <div class="text-muted small">Số điện thoại</div>
                <div class="fw-semibold">@Model.Customer.Phone</div>
            </div>
        </div>
    </div>
</div>

<div class="card">
    <div class="card-header">
        <h5 class="card-title mb-0">
            <i class="bi bi-receipt-cutoff me-2"></i>
            Lịch sử đơn hàng
        </h5>
    </div>
    <div class="card-body p-1">
        <table class="table table-bordered table-hover mb-0">
            <thead class="table-secondary">
                <tr>
                    <th style="width:120px;">Mã đơn</th>
                    <th style="width:160px;">Ngày đặt</th>
                    <th>Nhân viên phụ trách</th>
                    <th style="width:160px;">Trạng thái</th>
                    <th class="text-end" style="width:160px;">Tổng tiền</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Orders.Any())
                {
                    @foreach (var item in Model.Orders)
                    {
                        <tr>
                            <td>#@item.OrderID</td>
                            <td>@item.OrderedTime.ToString("dd/MM/yyyy")</td>
                            <td>@item.EmployeeName</td>
                            <td>@item.Status</td>
                            <td class="text-end">@item.TotalAmount.ToString("N0") đ</td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="5" class="text-center text-muted">Khách hàng này chưa có đơn hàng nào.</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
