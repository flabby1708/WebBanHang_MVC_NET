@model SV22T1020497.Models.Catalog.Category
@{
    ViewBag.Title = "Xóa loại hàng";
    string? photoUrl = CategoryImageHelper.ResolveCategoryImageUrl(Model.CategoryName, Model.Photo);
}
@section PageToolBar {
    <button type="submit" form="formDelete" class="btn btn-danger">
        <i class="bi bi-trash"></i>
        Xóa dữ liệu
    </button>

    <a href="~/Category" class="btn btn-secondary ms-1">
        <i class="bi bi-arrow-left"></i>
        Quay lại
    </a>
}

<div class="row justify-content-center">
    <div class="col-lg-8">
        <div class="card card-danger card-outline">
            <div class="card-header">
                <h5 class="mb-0">Xác nhận xóa loại hàng</h5>
            </div>
            <div class="card-body">
                <p>Bạn có chắc chắn muốn xóa loại hàng sau không?</p>
                <dl class="row mb-0">
                    <dt class="col-sm-3">Tên loại hàng</dt>
                    <dd class="col-sm-9">@Model.CategoryName</dd>

                    <dt class="col-sm-3">Mô tả</dt>
                    <dd class="col-sm-9">@Model.Description</dd>

                    <dt class="col-sm-3">Ảnh</dt>
                    <dd class="col-sm-9">
                        <img src="@(string.IsNullOrWhiteSpace(photoUrl) ? Url.Content("~/images/products/nophoto.png") : photoUrl)"
                             alt="@Model.CategoryName"
                             class="img-thumbnail"
                             style="max-height:180px;object-fit:contain;" />
                    </dd>
                </dl>

                <form id="formDelete" method="post" asp-controller="Category" asp-action="Delete" class="d-none">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" value="@Model.CategoryID" />
                </form>
            </div>
        </div>
    </div>
</div>
