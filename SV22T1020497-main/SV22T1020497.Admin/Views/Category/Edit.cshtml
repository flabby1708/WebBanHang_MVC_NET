@model SV22T1020497.Models.Catalog.Category
@{
    ViewBag.Title = "Cập nhật loại hàng";
}
@section PageToolBar {
    <button type="submit" form="formEdit" class="btn btn-primary">
        <i class="bi bi-save"></i>
        Lưu dữ liệu
    </button>

    <a href="~/Category" class="btn btn-secondary ms-1">
        <i class="bi bi-arrow-left"></i>
        Quay lại
    </a>
}

<div class="row justify-content-center">
    <div class="col-12">
        <div class="card card-primary card-outline">
            <div class="card-header">
                <h5 class="card-title mb-0">Thông tin loại hàng</h5>
            </div>

            <div class="card-body">
                <form id="formEdit" method="post" asp-controller="Category" asp-action="Edit">
                    @Html.AntiForgeryToken()
                    <input type="hidden" asp-for="CategoryID" />
                    <div class="mb-3">
                        <label class="form-label">Tên loại hàng</label>
                        <input asp-for="CategoryName" class="form-control" placeholder="Nhập tên loại hàng" autofocus />
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Mô tả</label>
                        <textarea asp-for="Description" class="form-control" rows="3" placeholder="Nhập mô tả loại hàng"></textarea>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
