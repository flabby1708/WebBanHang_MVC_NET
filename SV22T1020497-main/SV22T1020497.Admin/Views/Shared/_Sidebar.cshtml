@{
    var userData = User.GetUserData();
    bool canManageCustomers = userData?.HasAnyRole(WebUserRoles.Customers, WebUserRoles.SystemAdmin) == true;
    bool canManageProducts = userData?.HasAnyRole(WebUserRoles.Products, WebUserRoles.SystemAdmin) == true;
    bool canManageOrders = userData?.HasAnyRole(WebUserRoles.Orders, WebUserRoles.SystemAdmin) == true;
    bool canManageEmployees = userData?.HasRole(WebUserRoles.SystemAdmin) == true;
}

<aside class="app-sidebar admin-sidebar shadow" data-bs-theme="dark">
    <div class="sidebar-brand admin-sidebar__brand">
        <a href="~/" class="brand-link">
            <span class="admin-sidebar__logo">TS</span>
            <span class="brand-text">
                <strong>Tuna Shop</strong>
                <small>Management Hub</small>
            </span>
        </a>
    </div>

    <div class="sidebar-wrapper">
        <div class="admin-sidebar__section">
            <span class="admin-sidebar__section-title">Điều hướng</span>
            <nav class="mt-2">
                <ul class="nav sidebar-menu flex-column" data-lte-toggle="treeview" role="navigation" aria-label="Main navigation" data-accordion="false">
                    <li class="nav-item">
                        <a href="~/" class="nav-link">
                            <i class="nav-icon bi bi-grid-1x2"></i>
                            <p>Trang chủ</p>
                        </a>
                    </li>

                    @if (canManageCustomers || canManageProducts || canManageEmployees)
                    {
                        <li class="nav-header">Dữ liệu hệ thống</li>

                        @if (canManageProducts)
                        {
                            <li class="nav-item">
                                <a href="~/Supplier" class="nav-link">
                                    <i class="nav-icon bi bi-building"></i>
                                    <p>Nhà cung cấp</p>
                                </a>
                            </li>
                        }
                        @if (canManageCustomers)
                        {
                            <li class="nav-item">
                                <a href="~/Customer" class="nav-link">
                                    <i class="nav-icon bi bi-people"></i>
                                    <p>Khách hàng</p>
                                </a>
                            </li>
                        }
                        @if (canManageProducts)
                        {
                            <li class="nav-item">
                                <a href="~/Shipper" class="nav-link">
                                    <i class="nav-icon bi bi-truck"></i>
                                    <p>Người giao hàng</p>
                                </a>
                            </li>
                        }
                        @if (canManageEmployees)
                        {
                            <li class="nav-item">
                                <a href="~/Employee" class="nav-link">
                                    <i class="nav-icon bi bi-person-badge"></i>
                                    <p>Nhân viên</p>
                                </a>
                            </li>
                        }
                    }

                    @if (canManageProducts)
                    {
                        <li class="nav-header">Hàng hóa</li>
                        <li class="nav-item">
                            <a href="~/Category" class="nav-link">
                                <i class="nav-icon bi bi-tags"></i>
                                <p>Loại hàng</p>
                            </a>
                        </li>
                        <li class="nav-item">
                            <a href="~/Product" class="nav-link">
                                <i class="nav-icon bi bi-box-seam"></i>
                                <p>Mặt hàng</p>
                            </a>
                        </li>
                    }

                    @if (canManageOrders)
                    {
                        <li class="nav-header">Bán hàng</li>
                        <li class="nav-item">
                            <a href="~/Order/Create" class="nav-link">
                                <i class="nav-icon bi bi-cart-plus"></i>
                                <p>Lập đơn hàng</p>
                            </a>
                        </li>
                        <li class="nav-item">
                            <a href="~/Order" class="nav-link">
                                <i class="nav-icon bi bi-receipt-cutoff"></i>
                                <p>Quản lý đơn hàng</p>
                            </a>
                        </li>
                    }
                </ul>
            </nav>
        </div>
    </div>
</aside>
