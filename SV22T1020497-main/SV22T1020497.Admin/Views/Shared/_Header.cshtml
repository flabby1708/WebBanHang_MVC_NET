@{
    var userData = User.GetUserData();
    string displayName = userData?.DisplayName ?? userData?.UserName ?? "Người dùng";
    bool hasPhoto = !string.IsNullOrWhiteSpace(userData?.Photo);
    string photoUrl = hasPhoto ? Url.Content($"~/images/employees/{userData?.Photo}") : string.Empty;
}

<nav class="app-header navbar navbar-expand admin-header">
    <div class="container-fluid admin-header__inner">
        <div class="d-flex align-items-center gap-2">
            <a class="nav-link admin-header__toggle" data-lte-toggle="sidebar" href="#" role="button" aria-label="Mở menu">
                <i class="bi bi-list"></i>
            </a>
            <div class="admin-header__brand">
                <span class="admin-header__badge">Admin</span>
                <span class="admin-header__welcome">Hệ thống quản trị Tuna Shop</span>
            </div>
        </div>

        <ul class="navbar-nav ms-auto align-items-center">
            <li class="nav-item dropdown user-menu">
                <a href="#" class="nav-link admin-user dropdown-toggle" data-bs-toggle="dropdown">
                    @if (hasPhoto)
                    {
                        <img src="@photoUrl" class="admin-user__avatar" alt="@displayName" />
                    }
                    else
                    {
                        <span class="admin-user__avatar admin-user__avatar--icon" aria-hidden="true">
                            <i class="bi bi-shield-lock-fill"></i>
                        </span>
                    }
                    <span class="admin-user__meta d-none d-md-flex">
                        <strong>@displayName</strong>
                        @if (!string.IsNullOrWhiteSpace(userData?.Email))
                        {
                            <small>@userData.Email</small>
                        }
                    </span>
                </a>
                <ul class="dropdown-menu dropdown-menu-end admin-user__menu">
                    <li class="admin-user__menu-header">
                        @if (hasPhoto)
                        {
                            <img src="@photoUrl" class="admin-user__menu-avatar" alt="@displayName" />
                        }
                        else
                        {
                            <span class="admin-user__menu-avatar admin-user__avatar--icon" aria-hidden="true">
                                <i class="bi bi-person-workspace"></i>
                            </span>
                        }
                        <div>
                            <strong>@displayName</strong>
                            @if (!string.IsNullOrWhiteSpace(userData?.Email))
                            {
                                <small>@userData.Email</small>
                            }
                        </div>
                    </li>
                    <li><hr class="dropdown-divider" /></li>
                    <li>
                        <a href="~/Account/ChangePassword" class="dropdown-item">
                            <i class="bi bi-key me-2"></i>Đổi mật khẩu
                        </a>
                    </li>
                    <li>
                        <a href="~/Account/Logout" class="dropdown-item text-danger">
                            <i class="bi bi-box-arrow-right me-2"></i>Đăng xuất
                        </a>
                    </li>
                </ul>
            </li>
        </ul>
    </div>
</nav>
