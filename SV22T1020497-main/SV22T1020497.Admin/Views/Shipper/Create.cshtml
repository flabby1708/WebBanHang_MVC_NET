@model SV22T1020497.Models.Partner.Shipper
@{
    ViewBag.Title = "Bổ sung người giao hàng";
}
@section PageToolBar {
    <button type="submit" form="formCreate" class="btn btn-primary">
        <i class="bi bi-save"></i>
        Lưu dữ liệu
    </button>

    <a href="~/Shipper" class="btn btn-secondary ms-1">
        <i class="bi bi-arrow-left"></i>
        Quay lại
    </a>
}
<div class="row justify-content-center">
    <div class="col-12">
        <div class="card card-primary card-outline">
            <div class="card-header">
                <h5 class="card-title mb-0">
                    <i class="bi bi-truck me-2"></i>
                    Thông tin người giao hàng
                </h5>
            </div>

            <div class="card-body">
                <form id="formCreate" method="post" asp-controller="Shipper" asp-action="Create">
                    @Html.AntiForgeryToken()
                    <div class="mb-3">
                        <label class="form-label">Tên người giao hàng</label>
                        <input asp-for="ShipperName" class="form-control" placeholder="Nhập tên người giao hàng" autofocus />
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Điện thoại</label>
                        <input asp-for="Phone" class="form-control" placeholder="Nhập số điện thoại" />
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
