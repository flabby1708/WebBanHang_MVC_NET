@model IEnumerable<SV22T1020497.Models.Partner.Shipper>
@{
    ViewBag.Title = "Quản lý người giao hàng";
    int currentPage = ViewBag.CurrentPage ?? 1;
    int totalPages = ViewBag.TotalPages ?? 1;
    string searchValue = ViewBag.SearchValue ?? "";
}
@section PageToolBar {
    <a href="~/Shipper/Create" class="btn btn-primary d-flex align-items-center ms-1">
        <i class="bi bi-plus-lg me-1"></i>
        Bổ sung
    </a>
}

<div class="card mb-3">
    <div class="card-body">
        <form id="formSearch" method="get" action="~/Shipper">
            <div class="input-group">
                <input type="text"
                       class="form-control"
                       name="searchValue"
                       value="@searchValue"
                       placeholder="Tên người giao hàng..." autofocus />
                <button class="btn btn-info d-flex align-items-center">
                    <i class="bi bi-search me-1"></i>
                </button>
            </div>
        </form>
    </div>
</div>

<div class="mb-2 text-muted">
    Danh sách này có <strong>@(Model?.Count() ?? 0)</strong> người giao hàng
</div>

<div class="card">
    <div class="table-responsive">
        <table class="table table-bordered table-hover mb-0">
            <thead class="table-secondary">
                <tr>
                    <th style="width:100px">Mã người giao</th>
                    <th>Tên người giao hàng</th>
                    <th>Điện thoại</th>
                    <th class="text-center" style="width:100px">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null)
                {
                    foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.ShipperID</td>
                            <td>@item.ShipperName</td>
                            <td>@item.Phone</td>
                            <td class="text-center text-nowrap">
                                <a class="btn btn-sm btn-primary" href="~/Shipper/Edit/@item.ShipperID">
                                    <i class="bi bi-pencil"></i>
                                </a>
                                <a class="btn btn-sm btn-danger" href="~/Shipper/Delete/@item.ShipperID">
                                    <i class="bi bi-trash"></i>
                                </a>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
    <div class="card-footer">
        <ul class="pagination justify-content-center mb-0">
            @if (currentPage > 1)
            {
                <li class="page-item">
                    <a class="page-link" href="~/Shipper?page=1&searchValue=@searchValue">« Đầu</a>
                </li>
                <li class="page-item">
                    <a class="page-link" href="~/Shipper?page=@(currentPage - 1)&searchValue=@searchValue">‹ Trước</a>
                </li>
            }

            @for (int i = 1; i <= totalPages; i++)
            {
                if (i == currentPage)
                {
                    <li class="page-item active">
                        <span class="page-link">@i</span>
                    </li>
                }
                else
                {
                    <li class="page-item">
                        <a class="page-link" href="~/Shipper?page=@i&searchValue=@searchValue">@i</a>
                    </li>
                }
            }

            @if (currentPage < totalPages)
            {
                <li class="page-item">
                    <a class="page-link" href="~/Shipper?page=@(currentPage + 1)&searchValue=@searchValue">Sau</a>
                </li>
                <li class="page-item">
                    <a class="page-link" href="~/Shipper?page=@totalPages&searchValue=@searchValue">Cuối »</a>
                </li>
            }
        </ul>
    </div>
</div>
