@{
    ViewBag.Title = "Cập nhật ảnh";
}
@section PageToolBar {
    <button type="submit" form="formEditPhoto" class="btn btn-primary">
        <i class="bi bi-save"></i>
        Lưu ảnh
    </button>

    <a href="~/Product/Edit/1#photos" class="btn btn-secondary ms-1">
        <i class="bi bi-arrow-left"></i>
        Quay lại
    </a>
}

<div class="row justify-content-center">
    <div class="col-lg-8">
        <div class="card card-primary card-outline">
            <div class="card-header">
                <h5 class="mb-0">Thông tin ảnh mặt hàng</h5>
            </div>
            <div class="card-body">
                <form id="formEditPhoto" method="post" asp-controller="Product" asp-action="EditPhoto">
                    @Html.AntiForgeryToken()

                    <div class="row mb-3">
                        <label class="col-sm-3 fw-semibold">Ảnh</label>
                        <div class="col-sm-9">
                            <input type="file" name="uploadPhoto" class="form-control" />
                        </div>
                    </div>

                    <div class="row mb-3">
                        <label class="col-sm-3 fw-semibold">Xem trước</label>
                        <div class="col-sm-9">
                            <img src="~/images/products/demo.png" alt="Ảnh sản phẩm" class="img-thumbnail" style="max-height:140px;" />
                        </div>
                    </div>

                    <div class="row mb-3">
                        <label class="col-sm-3 fw-semibold">Mô tả</label>
                        <div class="col-sm-9">
                            <input type="text" name="Description" class="form-control" placeholder="Nhập mô tả ảnh" />
                        </div>
                    </div>

                    <div class="row mb-3">
                        <label class="col-sm-3 fw-semibold">Thứ tự hiển thị</label>
                        <div class="col-sm-9">
                            <input type="number" name="DisplayOrder" class="form-control" value="1" min="1" />
                        </div>
                    </div>

                    <div class="row mb-3">
                        <label class="col-sm-3 fw-semibold">Trạng thái</label>
                        <div class="col-sm-9 pt-2">
                            <div class="form-check">
                                <input type="checkbox" name="IsHidden" class="form-check-input" id="chkHidden" />
                                <label for="chkHidden" class="form-check-label">Ẩn ảnh</label>
                            </div>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
