@using Microsoft.AspNetCore.Mvc.Rendering
@model SV22T1020497.Models.Catalog.Product
@{
    ViewBag.Title = "Bổ sung mặt hàng";
    var categories = ViewBag.Categories as List<SelectListItem> ?? new List<SelectListItem>();
    var suppliers = ViewBag.Suppliers as List<SelectListItem> ?? new List<SelectListItem>();
}
@section PageToolBar {
    <button type="submit" form="formCreate" class="btn btn-primary">
        <i class="bi bi-save"></i>
        Lưu dữ liệu
    </button>

    <a href="~/Product" class="btn btn-secondary ms-1">
        <i class="bi bi-arrow-left"></i>
        Quay lại
    </a>
}
<div class="row justify-content-center">
    <div class="col-12">
        <div class="card card-primary card-outline">
            <div class="card-header">
                <h5 class="card-title mb-0">
                    <i class="bi bi-box me-2"></i>
                    Thông tin mặt hàng
                </h5>
            </div>

            <div class="card-body">
                <form id="formCreate" method="post" asp-controller="Product" asp-action="Create">
                    @Html.AntiForgeryToken()
                    <div class="mb-3">
                        <label class="form-label">Tên mặt hàng</label>
                        <input asp-for="ProductName" class="form-control" placeholder="Nhập tên mặt hàng" autofocus />
                        <span asp-validation-for="ProductName" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Mô tả</label>
                        <textarea asp-for="ProductDescription" class="form-control" rows="3" placeholder="Nhập mô tả mặt hàng"></textarea>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Loại hàng</label>
                            <select asp-for="CategoryID" class="form-select" asp-items="categories"></select>
                            <span asp-validation-for="CategoryID" class="text-danger"></span>
                        </div>

                        <div class="col-md-6 mb-3">
                            <label class="form-label">Nhà cung cấp</label>
                            <select asp-for="SupplierID" class="form-select" asp-items="suppliers"></select>
                            <span asp-validation-for="SupplierID" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Đơn vị tính</label>
                            <input asp-for="Unit" class="form-control" placeholder="Nhập đơn vị tính" />
                            <span asp-validation-for="Unit" class="text-danger"></span>
                        </div>

                        <div class="col-md-6 mb-3">
                            <label class="form-label">Giá bán</label>
                            <input asp-for="Price" type="number" step="0.01" class="form-control" placeholder="Nhập giá bán" />
                            <span asp-validation-for="Price" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Ảnh đại diện</label>
                        <input asp-for="Photo" class="form-control" placeholder="Nhập tên file hoặc đường dẫn ảnh" />
                    </div>

                    <div class="mb-3 form-check">
                        <input asp-for="IsSelling" class="form-check-input" />
                        <label class="form-check-label" asp-for="IsSelling">Đang bán</label>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
