@model SV22T1020497.Models.Catalog.Product
@{
    ViewBag.Title = "Xóa mặt hàng";
}
@section PageToolBar {
    <button type="submit" form="formDelete" class="btn btn-danger">
        <i class="bi bi-trash"></i>
        Xóa dữ liệu
    </button>

    <a href="~/Product" class="btn btn-secondary ms-1">
        <i class="bi bi-arrow-left"></i>
        Quay lại
    </a>
}

<div class="row justify-content-center">
    <div class="col-lg-9">
        <div class="card card-danger card-outline">
            <div class="card-header">
                <h5 class="mb-0">Xác nhận xóa mặt hàng</h5>
            </div>
            <div class="card-body">
                <p>Bạn có chắc chắn muốn xóa mặt hàng sau không?</p>
                <dl class="row mb-0">
                    <dt class="col-sm-4">Tên mặt hàng</dt>
                    <dd class="col-sm-8">@Model?.ProductName</dd>

                    <dt class="col-sm-4">Mã loại hàng</dt>
                    <dd class="col-sm-8">@Model?.CategoryID</dd>

                    <dt class="col-sm-4">Mã nhà cung cấp</dt>
                    <dd class="col-sm-8">@Model?.SupplierID</dd>

                    <dt class="col-sm-4">Đơn vị tính</dt>
                    <dd class="col-sm-8">@Model?.Unit</dd>

                    <dt class="col-sm-4">Giá bán</dt>
                    <dd class="col-sm-8">@Model?.Price.ToString("N0") đ</dd>

                    <dt class="col-sm-4">Trạng thái</dt>
                    <dd class="col-sm-8">@(Model?.IsSelling == true ? "Đang bán" : "Ngừng bán")</dd>

                    <dt class="col-sm-4">Mô tả</dt>
                    <dd class="col-sm-8">@Model?.ProductDescription</dd>
                </dl>

                <form id="formDelete" method="post" asp-controller="Product" asp-action="Delete" class="d-none">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" value="@Model?.ProductID" />
                </form>
            </div>
        </div>
    </div>
</div>
