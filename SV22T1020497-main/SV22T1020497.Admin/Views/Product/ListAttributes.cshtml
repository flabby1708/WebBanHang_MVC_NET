@model IEnumerable<SV22T1020497.Models.Catalog.ProductAttribute>
@{
    ViewBag.Title = "Thuộc tính mặt hàng";
    var product = ViewBag.Product as SV22T1020497.Models.Catalog.Product;
}
@section PageToolBar {
    <a class="btn btn-primary" href="~/Product/CreateAttribute/@(product?.ProductID ?? 0)">
        <i class="bi bi-plus"></i>
        Thêm thuộc tính
    </a>

    <a class="btn btn-secondary ms-1" href="~/Product/Edit/@(product?.ProductID ?? 0)">
        <i class="bi bi-arrow-left"></i>
        Quay lại mặt hàng
    </a>
}

<div class="row justify-content-center">
    <div class="col-12">
        <div class="card card-success card-outline">
            <div class="card-header">
                <h6 id="attributes" class="card-title mb-0">
                    <i class="bi bi-list-check me-2"></i>
                    Thuộc tính của @(product?.ProductName ?? "mặt hàng")
                </h6>
            </div>

            <div class="card-body p-1">
                <table class="table table-bordered table-hover mb-0">
                    <thead class="table-secondary">
                        <tr>
                            <th>Tên thuộc tính</th>
                            <th>Giá trị</th>
                            <th style="width:120px" class="text-center">Thứ tự</th>
                            <th style="width:100px"></th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.Any())
                        {
                            foreach (var item in Model)
                            {
                                <tr>
                                    <td>@item.AttributeName</td>
                                    <td>@item.AttributeValue</td>
                                    <td class="text-center">@item.DisplayOrder</td>
                                    <td class="text-center text-nowrap">
                                        <a class="btn btn-sm btn-primary" href="~/Product/EditAttribute/@item.ProductID?attributeId=@item.AttributeID">
                                            <i class="bi bi-pencil"></i>
                                        </a>
                                        <a class="btn btn-sm btn-danger" href="~/Product/DeleteAttribute/@item.ProductID?attributeId=@item.AttributeID">
                                            <i class="bi bi-trash"></i>
                                        </a>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="4" class="text-center text-muted py-4">Chưa có thuộc tính nào cho mặt hàng này.</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
