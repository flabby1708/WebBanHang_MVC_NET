@model IEnumerable<SV22T1020497.Models.Catalog.ProductPhoto>
@{
    ViewBag.Title = "Ảnh mặt hàng";
    var product = ViewBag.Product as SV22T1020497.Models.Catalog.Product;
}
@section PageToolBar {
    <a class="btn btn-primary" href="~/Product/CreatePhoto/@(product?.ProductID ?? 0)">
        <i class="bi bi-plus-circle"></i>
        Thêm ảnh
    </a>

    <a class="btn btn-secondary ms-1" href="~/Product/Edit/@(product?.ProductID ?? 0)">
        <i class="bi bi-arrow-left"></i>
        Quay lại mặt hàng
    </a>
}

<div class="row justify-content-center">
    <div class="col-12">
        <div class="card card-info card-outline">
            <div class="card-header">
                <h6 id="photos" class="mb-0">
                    <i class="bi bi-images me-2"></i>
                    Thư viện ảnh của @(product?.ProductName ?? "mặt hàng")
                </h6>
            </div>

            <div class="card-body p-1">
                <table class="table table-bordered table-hover mb-0">
                    <thead class="table-secondary">
                        <tr>
                            <th style="width:120px">Ảnh</th>
                            <th>Mô tả</th>
                            <th style="width:120px" class="text-center">Thứ tự</th>
                            <th style="width:120px">Hiển thị</th>
                            <th style="width:100px"></th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.Any())
                        {
                            foreach (var item in Model)
                            {
                                string photoUrl = ProductImageHelper.ResolveProductImageUrl(product?.ProductName, item.Photo)
                                    ?? Url.Content("~/images/products/nophoto.png");
                                <tr>
                                    <td class="text-center">
                                        <img src="@photoUrl" class="img-thumbnail" style="max-height:80px;" alt="Ảnh sản phẩm" />
                                    </td>
                                    <td>@item.Description</td>
                                    <td class="text-center">@item.DisplayOrder</td>
                                    <td class="text-center">
                                        @if (item.IsHidden)
                                        {
                                            <span class="badge bg-secondary">Ẩn</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-success">Hiện</span>
                                        }
                                    </td>
                                    <td class="text-center text-nowrap">
                                        <a class="btn btn-sm btn-primary" href="~/Product/EditPhoto/@item.ProductID?photoId=@item.PhotoID">
                                            <i class="bi bi-pencil"></i>
                                        </a>
                                        <a class="btn btn-sm btn-danger" href="~/Product/DeletePhoto/@item.ProductID?photoId=@item.PhotoID">
                                            <i class="bi bi-trash"></i>
                                        </a>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="5" class="text-center text-muted py-4">Chưa có ảnh nào cho mặt hàng này.</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
