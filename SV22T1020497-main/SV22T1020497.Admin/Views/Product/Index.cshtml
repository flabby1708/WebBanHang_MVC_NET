@model IEnumerable<SV22T1020497.Models.Catalog.Product>
@{
    ViewBag.Title = "Quản lý mặt hàng";
    int currentPage = ViewBag.CurrentPage ?? 1;
    int totalPages = ViewBag.TotalPages ?? 1;
    string searchValue = ViewBag.SearchValue ?? "";
    int startPage = Math.Max(1, currentPage - 2);
    int endPage = Math.Min(totalPages, currentPage + 2);
}
@section PageToolBar {
    <a href="~/Product/Create" class="btn btn-primary d-flex align-items-center ms-1">
        <i class="bi bi-plus-lg me-1"></i>
        Bổ sung
    </a>
}

<div class="card mb-3">
    <div class="card-body">
        <form id="formSearch" method="get" action="~/Product">
            <div class="input-group">
                <input type="text"
                       class="form-control"
                       name="searchValue"
                       value="@searchValue"
                       placeholder="Tên mặt hàng..." autofocus />
                <button class="btn btn-info d-flex align-items-center">
                    <i class="bi bi-search me-1"></i>
                </button>
            </div>
        </form>
    </div>
</div>

<div class="mb-2 text-muted">
    Danh sách này có <strong>@(Model?.Count() ?? 0)</strong> mặt hàng
</div>

<div class="card">
    <div class="table-responsive">
        <table class="table table-bordered table-hover mb-0">
            <thead class="table-secondary">
                <tr>
                    <th style="width:80px;">Ảnh</th>
                    <th>Mặt hàng</th>
                    <th style="width:120px;">Đơn vị</th>
                    <th style="width:140px;" class="text-end">Giá</th>
                    <th class="text-center" style="width:140px;">Trạng thái</th>
                    <th class="text-center" style="width:120px;">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null)
                {
                    foreach (var item in Model)
                    {
                        string? photoUrl = ProductImageHelper.ResolveProductImageUrl(item.ProductName, item.Photo);

                        <tr>
                            <td class="text-center align-middle">
                                @if (!string.IsNullOrWhiteSpace(photoUrl))
                                {
                                    <img src="@photoUrl" alt="@item.ProductName" class="img-thumbnail" style="width:64px;height:64px;object-fit:contain;" />
                                }
                                else
                                {
                                    <img src="~/images/products/nophoto.png" alt="@item.ProductName" class="img-thumbnail" style="width:64px;height:64px;object-fit:contain;" />
                                }
                            </td>
                            <td>
                                <strong>@item.ProductName</strong><br />
                                <span class="text-muted">@item.ProductDescription</span>
                            </td>
                            <td class="align-middle">@item.Unit</td>
                            <td class="text-end align-middle">@item.Price.ToString("N0") đ</td>
                            <td class="text-center align-middle">
                                @if (item.IsSelling == true)
                                {
                                    <span class="badge bg-success">Đang bán</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">Ngừng bán</span>
                                }
                            </td>
                            <td class="text-center text-nowrap align-middle">
                                <a class="btn btn-sm btn-primary" href="~/Product/Edit/@item.ProductID">
                                    <i class="bi bi-pencil"></i>
                                </a>
                                <a class="btn btn-sm btn-info" href="~/Product/Edit/@item.ProductID">
                                    <i class="bi bi-card-list"></i>
                                </a>
                                <a class="btn btn-sm btn-danger" href="~/Product/Delete/@item.ProductID">
                                    <i class="bi bi-trash"></i>
                                </a>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
    <div class="card-footer">
        <ul class="pagination pagination-sm justify-content-center flex-wrap gap-1 mb-0 product-pagination">
            @if (currentPage > 1)
            {
                <li class="page-item">
                    <a class="page-link" href="~/Product?page=1&searchValue=@searchValue">« Đầu</a>
                </li>
                <li class="page-item">
                    <a class="page-link" href="~/Product?page=@(currentPage - 1)&searchValue=@searchValue">‹ Trước</a>
                </li>
            }

            @if (startPage > 1)
            {
                <li class="page-item">
                    <a class="page-link" href="~/Product?page=1&searchValue=@searchValue">1</a>
                </li>

                @if (startPage > 2)
                {
                    <li class="page-item disabled">
                        <span class="page-link">...</span>
                    </li>
                }
            }

            @for (int i = startPage; i <= endPage; i++)
            {
                if (i == currentPage)
                {
                    <li class="page-item active">
                        <span class="page-link">@i</span>
                    </li>
                }
                else
                {
                    <li class="page-item">
                        <a class="page-link" href="~/Product?page=@i&searchValue=@searchValue">@i</a>
                    </li>
                }
            }

            @if (endPage < totalPages)
            {
                @if (endPage < totalPages - 1)
                {
                    <li class="page-item disabled">
                        <span class="page-link">...</span>
                    </li>
                }

                <li class="page-item">
                    <a class="page-link" href="~/Product?page=@totalPages&searchValue=@searchValue">@totalPages</a>
                </li>
            }

            @if (currentPage < totalPages)
            {
                <li class="page-item">
                    <a class="page-link" href="~/Product?page=@(currentPage + 1)&searchValue=@searchValue">Sau</a>
                </li>
                <li class="page-item">
                    <a class="page-link" href="~/Product?page=@totalPages&searchValue=@searchValue">Cuối »</a>
                </li>
            }
        </ul>
    </div>
</div>
