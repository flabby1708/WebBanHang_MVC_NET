@model SV22T1020497.Models.Catalog.ProductAttribute
@{
    ViewBag.Title = "Xóa thuộc tính";
    var product = ViewBag.Product as SV22T1020497.Models.Catalog.Product;
}
@section PageToolBar {
    <button type="submit" form="formDeleteAttribute" class="btn btn-danger">
        <i class="bi bi-trash"></i>
        Xóa thuộc tính
    </button>

    <a href="~/Product/Edit/@(product?.ProductID ?? Model.ProductID)#attributes" class="btn btn-secondary ms-1">
        <i class="bi bi-arrow-left"></i>
        Quay lại
    </a>
}

<div class="row justify-content-center">
    <div class="col-lg-8">
        <div class="card card-danger card-outline">
            <div class="card-header">
                <h5 class="mb-0">Xác nhận xóa thuộc tính</h5>
            </div>
            <div class="card-body">
                <form id="formDeleteAttribute" method="post" asp-action="DeleteAttribute" asp-route-id="@(product?.ProductID ?? Model.ProductID)" asp-route-attributeId="@Model.AttributeID">
                    @Html.AntiForgeryToken()
                    <p>Bạn có chắc chắn muốn xóa thuộc tính này không?</p>
                    <div class="mb-2"><strong>Tên thuộc tính:</strong> @Model.AttributeName</div>
                    <div><strong>Giá trị:</strong> @Model.AttributeValue</div>
                </form>
            </div>
        </div>
    </div>
</div>
