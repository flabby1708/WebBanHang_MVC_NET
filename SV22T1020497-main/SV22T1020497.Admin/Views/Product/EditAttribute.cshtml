@model SV22T1020497.Models.Catalog.ProductAttribute
@{
    ViewBag.Title = "Cập nhật thuộc tính";
    var product = ViewBag.Product as SV22T1020497.Models.Catalog.Product;
}
@section PageToolBar {
    <button type="submit" form="formEditAttribute" class="btn btn-primary">
        <i class="bi bi-save"></i>
        Lưu thuộc tính
    </button>

    <a href="~/Product/ListAttributes/@(product?.ProductID ?? Model.ProductID)" class="btn btn-secondary ms-1">
        <i class="bi bi-arrow-left"></i>
        Quay lại
    </a>
}

<div class="row justify-content-center">
    <div class="col-lg-8">
        <div class="card card-primary card-outline">
            <div class="card-header">
                <h5 class="mb-0">Thông tin thuộc tính mặt hàng</h5>
            </div>
            <div class="card-body">
                <form id="formEditAttribute" method="post" asp-controller="Product" asp-action="EditAttribute" asp-route-id="@(product?.ProductID ?? Model.ProductID)">
                    @Html.AntiForgeryToken()
                    <input type="hidden" asp-for="AttributeID" />
                    <input type="hidden" asp-for="ProductID" />
                    <div class="mb-3">
                        <label class="form-label">Tên thuộc tính</label>
                        <input asp-for="AttributeName" class="form-control" placeholder="Ví dụ: Màu sắc, Kích thước" autofocus />
                        <span asp-validation-for="AttributeName" class="text-danger"></span>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Giá trị thuộc tính</label>
                        <input asp-for="AttributeValue" class="form-control" placeholder="Ví dụ: Đỏ, XL, 500g" />
                        <span asp-validation-for="AttributeValue" class="text-danger"></span>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Thứ tự hiển thị</label>
                        <input asp-for="DisplayOrder" type="number" class="form-control" min="1" />
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
