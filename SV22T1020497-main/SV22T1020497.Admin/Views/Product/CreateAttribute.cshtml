@{
    ViewBag.Title = "Bổ sung thuộc tính";
}
@section PageToolBar {
    <button type="submit" form="formCreateAttribute" class="btn btn-primary">
        <i class="bi bi-save"></i>
        Lưu thuộc tính
    </button>

    <a href="~/Product/Edit/1#attributes" class="btn btn-secondary ms-1">
        <i class="bi bi-arrow-left"></i>
        Quay lại
    </a>
}

<div class="row justify-content-center">
    <div class="col-lg-8">
        <div class="card card-primary card-outline">
            <div class="card-header">
                <h5 class="mb-0">Thông tin thuộc tính mặt hàng</h5>
            </div>
            <div class="card-body">
                <form id="formCreateAttribute" method="post" asp-controller="Product" asp-action="CreateAttribute">
                    @Html.AntiForgeryToken()
                    <div class="mb-3">
                        <label class="form-label">Tên thuộc tính</label>
                        <input type="text" name="AttributeName" class="form-control" placeholder="Ví dụ: Màu sắc, Kích thước" autofocus />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Giá trị thuộc tính</label>
                        <input type="text" name="AttributeValue" class="form-control" placeholder="Ví dụ: Đỏ, XL, 500g" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Thứ tự hiển thị</label>
                        <input type="number" name="DisplayOrder" class="form-control" value="1" min="1" />
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
