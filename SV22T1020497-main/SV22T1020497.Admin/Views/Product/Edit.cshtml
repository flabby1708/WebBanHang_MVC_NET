@model SV22T1020497.Models.Catalog.Product
@{
    ViewBag.Title = "Cập nhật mặt hàng";
}
@section PageToolBar {
    <button type="submit" form="formEdit" class="btn btn-primary">
        <i class="bi bi-save"></i>
        Lưu dữ liệu
    </button>

    <a href="~/Product/ListAttributes/@Model.ProductID" class="btn btn-info ms-1">
        <i class="bi bi-list-check"></i>
        Thuộc tính
    </a>

    <a href="~/Product/ListPhotos/@Model.ProductID" class="btn btn-warning ms-1">
        <i class="bi bi-images"></i>
        Ảnh phụ
    </a>

    <a href="~/Product" class="btn btn-secondary ms-1">
        <i class="bi bi-arrow-left"></i>
        Quay lại
    </a>
}

<div class="row justify-content-center">
    <div class="col-12">
        <div class="card card-primary card-outline">
            <div class="card-header">
                <h5 class="card-title mb-0">Thông tin mặt hàng</h5>
            </div>

            <div class="card-body">
                <form id="formEdit" method="post" asp-controller="Product" asp-action="Edit">
                    @Html.AntiForgeryToken()
                    <input type="hidden" asp-for="ProductID" />

                    <div class="row mb-3">
                        <label class="col-sm-3 col-form-label">Tên mặt hàng</label>
                        <div class="col-sm-9">
                            <input asp-for="ProductName" class="form-control" placeholder="Nhập tên mặt hàng" autofocus />
                        </div>
                    </div>

                    <div class="row mb-3">
                        <label class="col-sm-3 col-form-label">Mã loại hàng</label>
                        <div class="col-sm-3">
                            <input asp-for="CategoryID" type="number" class="form-control" placeholder="Nhập mã loại hàng" />
                        </div>

                        <label class="col-sm-2 col-form-label text-end">Mã nhà cung cấp</label>
                        <div class="col-sm-4">
                            <input asp-for="SupplierID" type="number" class="form-control" placeholder="Nhập mã nhà cung cấp" />
                        </div>
                    </div>

                    <div class="row mb-3">
                        <label class="col-sm-3 col-form-label">Đơn vị tính</label>
                        <div class="col-sm-3">
                            <input asp-for="Unit" class="form-control" placeholder="Cái, hộp, kg..." />
                        </div>

                        <label class="col-sm-2 col-form-label text-end">Giá bán</label>
                        <div class="col-sm-4">
                            <input asp-for="Price" type="number" step="0.01" class="form-control" />
                        </div>
                    </div>

                    <div class="row mb-3">
                        <label class="col-sm-3 col-form-label">Trạng thái</label>
                        <div class="col-sm-9 pt-2">
                            <div class="form-check">
                                <input asp-for="IsSelling" class="form-check-input" />
                                <label asp-for="IsSelling" class="form-check-label">Đang bán</label>
                            </div>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <label class="col-sm-3 col-form-label">Ảnh</label>
                        <div class="col-sm-9">
                            <input asp-for="Photo" class="form-control" placeholder="Nhập đường dẫn ảnh" />
                        </div>
                    </div>

                    <div class="row mb-3">
                        <label class="col-sm-3 col-form-label">Mô tả</label>
                        <div class="col-sm-9">
                            <textarea asp-for="ProductDescription" class="form-control" rows="4" placeholder="Nhập mô tả mặt hàng"></textarea>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
