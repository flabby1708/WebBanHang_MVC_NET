@model SV22T1020497.Models.HR.Employee
@{
    ViewBag.Title = "Thêm nhân viên";
}
@section PageToolBar {
    <button type="submit" form="formCreate" class="btn btn-primary">
        <i class="bi bi-save"></i>
        Lưu dữ liệu
    </button>

    <a href="~/Employee" class="btn btn-secondary ms-1">
        <i class="bi bi-arrow-left"></i>
        Quay lại
    </a>
}
<div class="row justify-content-center">
    <div class="col-12">
        <div class="card card-primary card-outline">
            <div class="card-header">
                <h5 class="card-title mb-0">
                    <i class="bi bi-person-badge me-2"></i>
                    Thông tin nhân viên
                </h5>
            </div>

            <div class="card-body">
                <form id="formCreate" method="post" asp-controller="Employee" asp-action="Create">
                    @Html.AntiForgeryToken()
                    <div class="mb-3">
                        <label class="form-label">Họ và tên</label>
                        <input asp-for="FullName" class="form-control" placeholder="Nhập họ và tên" autofocus />
                    </div>

                    <div class="mb-3">
                        <label class="form-label">NgĂ y sinh</label>
                        <input asp-for="BirthDate" type="date" class="form-control" />
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Điện thoại</label>
                            <input asp-for="Phone" class="form-control" placeholder="Nhập số điện thoại" />
                        </div>

                        <div class="col-md-6 mb-3">
                            <label class="form-label">Email</label>
                            <input asp-for="Email" class="form-control" placeholder="Nhập email" />
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Địa chỉ</label>
                        <textarea asp-for="Address" class="form-control" rows="3" placeholder="Nhập địa chỉ"></textarea>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Mật khẩu</label>
                        <input asp-for="Password" type="password" class="form-control" placeholder="Nhập mật khẩu" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Ảnh</label>
                        <input asp-for="Photo" class="form-control" placeholder="Nhập đường dẫn ảnh" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Vai trĂ²</label>
                        <input asp-for="RoleNames" class="form-control" placeholder="Nhập vai trò (phân cách bằng dấu phẩy)" />
                    </div>

                    <div class="mb-3 form-check">
                        <input asp-for="IsWorking" class="form-check-input" />
                        <label class="form-check-label" asp-for="IsWorking">Đang làm việc</label>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
