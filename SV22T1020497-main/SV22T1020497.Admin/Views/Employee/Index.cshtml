@model IEnumerable<SV22T1020497.Models.HR.Employee>
@{
    ViewBag.Title = "Quản lý nhân viên";
    int currentPage = ViewBag.CurrentPage ?? 1;
    int totalPages = ViewBag.TotalPages ?? 1;
    string searchValue = ViewBag.SearchValue ?? "";
}
@section PageToolBar {
    <a href="~/Employee/Create" class="btn btn-primary d-flex align-items-center ms-1">
        <i class="bi bi-plus-circle me-1"></i>
        Bổ sung
    </a>
}
<div class="card mb-3">
    <div class="card-body">
        <form id="formSearch" method="get" action="~/Employee">
            <div class="input-group">
                <input type="text"
                       class="form-control"
                       name="searchValue"
                       value="@searchValue"
                       placeholder="Tên nhân viên..." autofocus />
                <button class="btn btn-info d-flex align-items-center">
                    <i class="bi bi-search me-1"></i>
                </button>
            </div>
        </form>
    </div>
</div>

<div class="mb-2 text-muted">
    Danh sách này có <strong>@(Model?.Count() ?? 0)</strong> nhân viên
</div>

<div class="card">
    <div class="card-body p-1">
        <table class="table table-bordered table-hover mb-0">
            <thead class="table-secondary">
                <tr>
                    <th>Họ tên</th>
                    <th>Ngày sinh</th>
                    <th>Điện thoại</th>
                    <th>Email</th>
                    <th>Địa chỉ</th>
                    <th class="text-center" style="width:140px;">Trạng thái</th>
                    <th class="text-center" style="width:150px;">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null)
                {
                    foreach (var emp in Model)
                    {
                        <tr>
                            <td>@emp.FullName</td>
                            <td>@(emp.BirthDate?.ToString("dd/MM/yyyy"))</td>
                            <td>@emp.Phone</td>
                            <td>@emp.Email</td>
                            <td>@emp.Address</td>
                            <td class="text-center">
                                @if (emp.IsWorking == true)
                                {
                                    <span class="badge bg-success">Đang làm việc</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">Đã nghỉ việc</span>
                                }
                            </td>
                            <td class="text-center text-nowrap">
                                <a href="~/Employee/Edit/@emp.EmployeeID" class="btn btn-sm btn-primary" title="Cập nhật">
                                    <i class="bi bi-pencil"></i>
                                </a>
                                <a href="~/Employee/Delete/@emp.EmployeeID" class="btn btn-sm btn-danger" title="Xóa">
                                    <i class="bi bi-trash"></i>
                                </a>
                                <a href="~/Employee/ChangePassword/@emp.EmployeeID" class="btn btn-sm btn-warning ms-1" title="Đổi mật khẩu">
                                    <i class="bi bi-key"></i>
                                </a>
                                <a href="~/Employee/ChangeRole/@emp.EmployeeID" class="btn btn-sm btn-info" title="Phân quyền">
                                    <i class="bi bi-shield-check"></i>
                                </a>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>

    <div class="card-footer">
        <ul class="pagination justify-content-center mb-0">
            @if (currentPage > 1)
            {
                <li class="page-item">
                    <a class="page-link" href="~/Employee?page=1&searchValue=@searchValue">« Đầu</a>
                </li>
                <li class="page-item">
                    <a class="page-link" href="~/Employee?page=@(currentPage - 1)&searchValue=@searchValue">‹ Trước</a>
                </li>
            }

            @for (int i = 1; i <= totalPages; i++)
            {
                if (i == currentPage)
                {
                    <li class="page-item active">
                        <span class="page-link">@i</span>
                    </li>
                }
                else
                {
                    <li class="page-item">
                        <a class="page-link" href="~/Employee?page=@i&searchValue=@searchValue">@i</a>
                    </li>
                }
            }

            @if (currentPage < totalPages)
            {
                <li class="page-item">
                    <a class="page-link" href="~/Employee?page=@(currentPage + 1)&searchValue=@searchValue">Sau</a>
                </li>
                <li class="page-item">
                    <a class="page-link" href="~/Employee?page=@totalPages&searchValue=@searchValue">Cuối »</a>
                </li>
            }
        </ul>
    </div>
</div>
