@model IEnumerable<SV22T1020497.Models.Partner.Supplier>
@{
    ViewBag.Title = "Quản lý nhà cung cấp";
    int currentPage = ViewBag.CurrentPage ?? 1;
    int totalPages = ViewBag.TotalPages ?? 1;
    string searchValue = ViewBag.SearchValue ?? "";
}
@section PageToolBar {
    <a href="~/Supplier/Create" class="btn btn-primary d-flex align-items-center ms-1">
        <i class="bi bi-plus-circle me-1"></i>
        Bổ sung
    </a>
}
<div class="card mb-3">
    <div class="card-body">
        <form id="formSearch" method="get" action="~/Supplier">
            <div class="input-group">
                <input type="text"
                       class="form-control"
                       name="searchValue"
                       value="@searchValue"
                       placeholder="Tên nhà cung cấp..." autofocus />
                <button class="btn btn-info d-flex align-items-center">
                    <i class="bi bi-search me-1"></i>
                </button>
            </div>
        </form>
    </div>
</div>

<div class="mb-2 text-muted">
    Danh sách này có <strong>@(Model?.Count() ?? 0)</strong> nhà cung cấp
</div>

<div class="card">
    <div class="card-body p-1">
        <table class="table table-bordered table-hover mb-0">
            <thead class="table-secondary">
                <tr>
                    <th>Tên nhà cung cấp</th>
                    <th>Tên giao dịch</th>
                    <th>Điện thoại</th>
                    <th>Email</th>
                    <th>Địa chỉ</th>
                    <th>Tỉnh / Thành</th>
                    <th class="text-center" style="width:120px;">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null)
                {
                    foreach (var s in Model)
                    {
                        <tr>
                            <td>@s.SupplierName</td>
                            <td>@s.ContactName</td>
                            <td>@s.Phone</td>
                            <td>@s.Email</td>
                            <td>@s.Address</td>
                            <td>@s.Province</td>
                            <td class="text-center text-nowrap">
                                <a href="~/Supplier/Edit/@s.SupplierID" class="btn btn-sm btn-primary me-1">
                                    <i class="bi bi-pencil"></i>
                                </a>
                                <a href="~/Supplier/Delete/@s.SupplierID" class="btn btn-sm btn-danger">
                                    <i class="bi bi-trash"></i>
                                </a>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
    <div class="card-footer">
        <ul class="pagination justify-content-center mb-0">
            @if (currentPage > 1)
            {
                <li class="page-item">
                    <a class="page-link" href="~/Supplier?page=1&searchValue=@searchValue">« Đầu</a>
                </li>
                <li class="page-item">
                    <a class="page-link" href="~/Supplier?page=@(currentPage - 1)&searchValue=@searchValue">‹ Trước</a>
                </li>
            }

            @for (int i = 1; i <= totalPages; i++)
            {
                if (i == currentPage)
                {
                    <li class="page-item active">
                        <span class="page-link">@i</span>
                    </li>
                }
                else
                {
                    <li class="page-item">
                        <a class="page-link" href="~/Supplier?page=@i&searchValue=@searchValue">@i</a>
                    </li>
                }
            }

            @if (currentPage < totalPages)
            {
                <li class="page-item">
                    <a class="page-link" href="~/Supplier?page=@(currentPage + 1)&searchValue=@searchValue">Sau</a>
                </li>
                <li class="page-item">
                    <a class="page-link" href="~/Supplier?page=@totalPages&searchValue=@searchValue">Cuối »</a>
                </li>
            }
        </ul>
    </div>
</div>
