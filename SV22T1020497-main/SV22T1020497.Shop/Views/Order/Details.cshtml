@model OrderDetailsViewModel
@{
    ViewData["Title"] = $"Đơn hàng #{Model.Order.OrderID}";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="h3 mb-1">Đơn hàng #@Model.Order.OrderID</h1>
        <div class="text-secondary">Đặt lúc @Model.Order.OrderTime.ToString("dd/MM/yyyy HH:mm")</div>
    </div>
    <span class="badge text-bg-secondary fs-6">@Model.Order.Status.GetDescription()</span>
</div>

<div class="row g-4">
    <div class="col-lg-8">
        <div class="card border-0 shadow-sm">
            <div class="card-body p-4">
                <h2 class="h5 mb-3">Sản phẩm trong đơn</h2>
                <div class="table-responsive">
                    <table class="table align-middle mb-0">
                        <thead>
                            <tr>
                                <th>Sản phẩm</th>
                                <th>Đơn giá</th>
                                <th>Số lượng</th>
                                <th>Thành tiền</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model.Details)
                            {
                                <tr>
                                    <td>
                                        <div class="fw-semibold">@item.ProductName</div>
                                        <div class="small text-secondary">Đơn vị: @item.Unit</div>
                                    </td>
                                    <td>@item.SalePrice.ToString("N0") đ</td>
                                    <td>@item.Quantity</td>
                                    <td class="fw-semibold">@item.TotalPrice.ToString("N0") đ</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <div class="col-lg-4">
        <div class="card border-0 shadow-sm">
            <div class="card-body p-4">
                <h2 class="h5 mb-3">Thông tin giao hàng</h2>
                <div class="mb-2"><strong>Tỉnh/thành:</strong> @Model.Order.DeliveryProvince</div>
                <div class="mb-2"><strong>Địa chỉ:</strong> @Model.Order.DeliveryAddress</div>
                <div class="mb-2"><strong>Người giao:</strong> @(string.IsNullOrWhiteSpace(Model.Order.ShipperName) ? "Chưa phân công" : Model.Order.ShipperName)</div>
                <hr />
                <div class="d-flex justify-content-between fw-semibold">
                    <span>Tổng thanh toán</span>
                    <span class="text-danger">@Model.TotalAmount.ToString("N0") đ</span>
                </div>
            </div>
        </div>
    </div>
</div>
