@model CheckoutViewModel
@{
    ViewData["Title"] = "Đặt mua hàng";
}

<div class="row g-4">
    <div class="col-lg-7">
        <section class="shop-form-shell">
            <div class="shop-form-panel">
                <span class="shop-section__eyebrow">Thông tin giao hàng</span>
                <h1 class="shop-form-title">Xác nhận nơi nhận hàng</h1>
                <p class="shop-form-subtitle">Điền địa chỉ giao nhận để hệ thống hoàn tất đơn hàng của bạn.</p>

                <form method="post" asp-action="Checkout">
                    @Html.AntiForgeryToken()
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="mb-3">
                        <label asp-for="DeliveryProvince" class="form-label"></label>
                        <select asp-for="DeliveryProvince" asp-items="ViewBag.Provinces" class="form-select"></select>
                        <span asp-validation-for="DeliveryProvince" class="text-danger"></span>
                    </div>

                    <div class="mb-4">
                        <label asp-for="DeliveryAddress" class="form-label"></label>
                        <input asp-for="DeliveryAddress" class="form-control" />
                        <span asp-validation-for="DeliveryAddress" class="text-danger"></span>
                    </div>

                    <button type="submit" class="btn btn-primary shop-btn-primary">Xác nhận đặt hàng</button>
                </form>
            </div>
        </section>
    </div>

    <div class="col-lg-5">
        <section class="shop-mini-card h-100">
            <div class="shop-form-panel">
                <span class="shop-section__eyebrow">Tóm tắt đơn hàng</span>
                <h2 class="shop-form-title h3">Sản phẩm đã chọn</h2>

                @foreach (var item in Model.Items)
                {
                    <div class="d-flex justify-content-between border-bottom py-3">
                        <div>
                            <div class="fw-semibold">@item.ProductName</div>
                            <div class="small text-secondary">SL: @item.Quantity</div>
                        </div>
                        <div>@item.TotalPrice.ToString("N0") đ</div>
                    </div>
                }

                <div class="d-flex justify-content-between pt-3 fw-semibold">
                    <span>Tổng thanh toán</span>
                    <span class="shop-price">@Model.TotalAmount.ToString("N0") đ</span>
                </div>
            </div>
        </section>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
