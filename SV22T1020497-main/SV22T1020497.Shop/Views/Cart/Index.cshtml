@model CartViewModel
@{
    ViewData["Title"] = "Giỏ hàng";
}

<div class="shop-cart-head">
    <div>
        <span class="shop-section__eyebrow">Giỏ mua sắm</span>
        <h1 class="shop-section__title mb-1">Sẵn sàng hoàn tất đơn hàng</h1>
        <div class="shop-section__subtitle">Kiểm tra nhanh sản phẩm, số lượng và tổng tiền trước khi đặt mua.</div>
    </div>
    <a asp-controller="Product" asp-action="Index" class="btn btn-outline-primary shop-btn-soft">Tiếp tục mua sắm</a>
</div>

@if (!Model.Items.Any())
{
    <div class="alert alert-info shop-alert">Giỏ hàng của bạn đang trống.</div>
}
else
{
    <section class="shop-cart-shell">
        <div class="table-responsive">
            <table class="table align-middle mb-0 shop-cart-table">
                <thead>
                    <tr>
                        <th>Sản phẩm</th>
                        <th style="width: 140px;">Đơn giá</th>
                        <th style="width: 220px;">Số lượng</th>
                        <th style="width: 140px;">Thành tiền</th>
                        <th style="width: 120px;"></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.Items)
                    {
                        <tr>
                            <td>
                                <div class="fw-semibold">@item.ProductName</div>
                                <div class="small text-secondary">Đơn vị: @item.Unit</div>
                            </td>
                            <td>@item.SalePrice.ToString("N0") đ</td>
                            <td>
                                <form method="post" asp-action="Update" class="d-flex gap-2">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="productId" value="@item.ProductID" />
                                    <input type="number" name="quantity" value="@item.Quantity" min="0" class="form-control" />
                                    <button type="submit" class="btn btn-outline-primary shop-btn-soft">Cập nhật</button>
                                </form>
                            </td>
                            <td class="fw-semibold">@item.TotalPrice.ToString("N0") đ</td>
                            <td>
                                <form method="post" asp-action="Remove">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="productId" value="@item.ProductID" />
                                    <button type="submit" class="btn btn-outline-danger">Xóa</button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        <div class="shop-cart-summary d-flex justify-content-between align-items-center flex-wrap gap-3">
            <div class="fs-5 fw-semibold">Tổng cộng: <span class="shop-price">@Model.TotalAmount.ToString("N0") đ</span></div>
            <a asp-action="Checkout" class="btn btn-primary shop-btn-primary">Tiến hành đặt hàng</a>
        </div>
    </section>
}
