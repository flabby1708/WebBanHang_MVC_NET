@model ProductDetailsViewModel
@{
    ViewData["Title"] = Model.Product.ProductName;
    string mainPhoto = Model.Photos.FirstOrDefault()?.Photo ?? Model.Product.Photo ?? "";
    string? imageUrl = ProductImageHelper.ResolveProductImageUrl(Model.Product.ProductName, mainPhoto);
}

<div class="row g-4 align-items-start">
    <div class="col-lg-6">
        <section class="shop-detail-card">
            <div class="shop-detail-gallery ratio ratio-4x3">
                @if (!string.IsNullOrWhiteSpace(imageUrl))
                {
                    <img src="@imageUrl"
                         alt="@Model.Product.ProductName"
                         class="w-100 h-100 object-fit-contain p-3" />
                }
                else
                {
                    <div class="d-flex align-items-center justify-content-center text-secondary">
                        Không có ảnh sản phẩm
                    </div>
                }
            </div>
        </section>
    </div>

    <div class="col-lg-6">
        <section class="shop-detail-card">
            <div class="shop-detail-content">
                <span class="shop-section__eyebrow">Chi tiết sản phẩm</span>
                <h1>@Model.Product.ProductName</h1>
                <p>@(string.IsNullOrWhiteSpace(Model.Product.ProductDescription) ? "Sản phẩm đang được cập nhật mô tả chi tiết." : Model.Product.ProductDescription)</p>

                <div class="shop-price mb-2">@Model.Product.Price.ToString("N0") đ</div>

                <div class="shop-detail-meta">
                    <span>Đơn vị: @Model.Product.Unit</span>
                    <span>Sẵn sàng đặt hàng</span>
                </div>

                <form method="post" asp-controller="Cart" asp-action="Add" class="row g-3 mt-1">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="productId" value="@Model.Product.ProductID" />
                    <div class="col-sm-4">
                        <label class="form-label">Số lượng</label>
                        <input type="number" name="quantity" value="@Model.Quantity" min="1" class="form-control" />
                    </div>
                    <div class="col-sm-8 d-flex align-items-end">
                        <button type="submit" class="btn btn-primary shop-btn-primary w-100">Thêm vào giỏ hàng</button>
                    </div>
                </form>
            </div>
        </section>
    </div>
</div>

@if (Model.Attributes.Any())
{
    <section class="shop-detail-card shop-attr-card">
        <h2 class="shop-section__title fs-4">Thông số sản phẩm</h2>
        <div class="table-responsive mt-3">
            <table class="table mb-0">
                <tbody>
                    @foreach (var item in Model.Attributes)
                    {
                        <tr>
                            <th style="width: 30%;">@item.AttributeName</th>
                            <td>@item.AttributeValue</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </section>
}
