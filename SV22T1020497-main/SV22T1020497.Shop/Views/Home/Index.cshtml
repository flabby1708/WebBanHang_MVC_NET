@{
    ViewData["Title"] = "Trang chủ";
}

<div class="p-4 p-lg-5 mb-4 bg-white rounded-3 shadow-sm">
    <div class="container-fluid py-2">
        <h1 class="display-6 fw-semibold">LiteCommerce Shop</h1>
        <p class="col-lg-8 fs-5 text-secondary mb-4">
            Nền tảng mua sắm dành cho khách hàng. Mình đã dựng xong phần nền tài khoản để bạn tiếp tục làm danh mục sản phẩm, giỏ hàng và đơn hàng.
        </p>
        <div class="d-flex flex-wrap gap-2">
            <a class="btn btn-dark btn-lg" asp-controller="Product" asp-action="Index">Xem sản phẩm</a>
            <a class="btn btn-primary btn-lg" asp-controller="Account" asp-action="Register">Tạo tài khoản</a>
            <a class="btn btn-outline-secondary btn-lg" asp-controller="Account" asp-action="Login">Đăng nhập</a>
        </div>
    </div>
</div>
