@{
    ViewData["Title"] = "Trang chủ";
}

<section class="shop-hero">
    <div class="row align-items-center g-4">
        <div class="col-lg-7">
            <span class="shop-hero__eyebrow">Mua sắm trực tuyến</span>
            <h1 class="shop-hero__title">Tuna Shop mang lại trải nghiệm mua hàng sáng sủa, nhanh và dễ chọn hơn.</h1>
            <p class="shop-hero__text">
                Khám phá danh mục sản phẩm đã được làm mới về hình ảnh, bố cục và cảm giác sử dụng.
                Mọi luồng backend vẫn giữ nguyên, còn phần hiển thị được tinh chỉnh để trông hiện đại và thân thiện hơn.
            </p>
            <div class="shop-hero__actions">
                <a class="btn btn-primary btn-lg shop-btn-primary" asp-controller="Product" asp-action="Index">Khám phá sản phẩm</a>
                <a class="btn btn-outline-primary btn-lg shop-btn-soft" asp-controller="Account" asp-action="Register">Tạo tài khoản</a>
                <a class="btn btn-outline-primary btn-lg shop-btn-soft" asp-controller="Account" asp-action="Login">Đăng nhập</a>
            </div>
        </div>
        <div class="col-lg-5">
            <div class="shop-chip-grid">
                <div class="shop-chip-card">
                    <strong>Danh mục trực quan</strong>
                    <span>Bộ lọc rõ ràng, card sản phẩm dễ xem hơn.</span>
                </div>
                <div class="shop-chip-card">
                    <strong>Ảnh đồng bộ</strong>
                    <span>Tận dụng đúng thư mục ảnh sản phẩm hiện có.</span>
                </div>
                <div class="shop-chip-card">
                    <strong>Màu sắc tươi sáng</strong>
                    <span>Tông xanh ngọc và xanh dương nhẹ mắt hơn.</span>
                </div>
            </div>
        </div>
    </div>
</section>
